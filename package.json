{
  "name": "mermaid_mcp_tool",
  "version": "1.0.0",
  "description": "MCP Server for validating Mermaid diagram syntax using the same mermaid package version as the frontend (11.12.1).",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mermaid-mcp-tool": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "jsdom": "^25.0.1",
    "mermaid": "11.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
